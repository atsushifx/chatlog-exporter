# ignore words for Python files, including pycache and pybuilder
# cspell:words pycache codz pybuilder

##  General
#   OS specific files
.DS_Store
thumbs.db

#   logs, patches
*.log
*.diff
*.patch

#   history, cache
.history/
.cache/
# **/*cache


#   backup/swap/temp
$~*
~*
*~
*.tmp
*.swp
*.lock

# session files
*session.json
*session
**/*session.json
**/*session

# .env files
.env*
.env.*

## Development tools (installed locally)
.tools/

## Worktrees
# worktree base dir
.worktrees/

## AI generated files

## Coding AI depended
# SDD (Spec-Driven Development) files
**/.cc-sdd/

# claude code setting
.claude/*

# agents can tracking
!.claude/agents/
!.claude/agents/**
!.claude/rules/
!.claude/rules/**
!.claude/commands/
!.claude/commands/**

# MCP server dependency files
.cocoindex_code/
.serena/
.lsmcp/

## Temporary directories are never tracked
temp/
tmp/
**/temp/
**/tmp/

##  Editor
#   VSCode
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
!.vscode/*.code-snippets
!.vscode/cspell*

## Node
node_modules/

### Generated by gibo (https://github.com/simonwhitaker/gibo)
### https://raw.github.com/github/gitignore/b4105e73e493bb7a20b5d7ea35efd5780ca44938/Python.gitignore

# Byte-compiled / optimized / DLL files
__pycache__/
*.py[codz]
*$py.class
*.pyc

# C extensions
*.so

# PyInstaller
#   Usually these files are written by a python script from a template
#   before PyInstaller builds the exe, so as to inject date/other infos into it.
*.manifest
*.spec


# Translations
*.mo
*.pot

# Django stuff:
*.log


# Sphinx documentation
docs/_build/

# PyBuilder
.pybuilder/
target/

# Jupyter Notebook
